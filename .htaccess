# Redirige dominio sin www a dominio con www, preservando esquema y ruta
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Coincide solo con dominios de segundo nivel (ej: dominio.tld)
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteCond %{HTTP_HOST} ^([^.]+\.[^.]+)$ [NC]
  RewriteRule ^ %{REQUEST_SCHEME}://www.%1%{REQUEST_URI} [R=301,L]
</IfModule>

# ─── Compresión GZIP ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE image/svg+xml application/json
  AddOutputFilterByType DEFLATE font/woff2 font/woff font/ttf
</IfModule>

# ─── Caché de navegador ─────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Imágenes: 1 año
  ExpiresByType image/webp   "access plus 1 year"
  ExpiresByType image/jpeg   "access plus 1 year"
  ExpiresByType image/png    "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Vídeo: 1 mes
  ExpiresByType video/mp4    "access plus 1 month"

  # Fuentes: 1 año
  ExpiresByType font/woff2   "access plus 1 year"
  ExpiresByType font/woff    "access plus 1 year"
  ExpiresByType font/ttf     "access plus 1 year"

  # CSS y JS: 1 mes (se pueden forzar nuevas versiones con query string)
  ExpiresByType text/css              "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript       "access plus 1 month"

  # HTML: sin caché (siempre fresco)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ─── Headers de caché adicionales ───────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|mp4|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
